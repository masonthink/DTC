# 生产环境变量模板（复制为 .env.prod 并填入真实值）
# 此文件由 docker-compose.prod.yml 通过 env_file 加载

# ── Docker 镜像 ────────────────────────────────────────────────────────────────
# GitHub Container Registry 镜像地址，GitHub Actions 自动更新
BACKEND_IMAGE=ghcr.io/mason2047/digital-twin-backend:latest

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_VERSION=0.1.0
SERVER_PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# postgres 容器内部密码（docker-compose.prod.yml 读取 ${POSTGRES_PASSWORD}）
POSTGRES_PASSWORD=replace_with_strong_password
DATABASE_URL=postgresql://dtc:replace_with_strong_password@postgres:5432/digital_twin_community?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=replace_with_strong_password
REDIS_ADDR=redis:6379

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6334
QDRANT_TLS_ENABLED=false
# 自建 Qdrant 不需要 API Key，留空即可
QDRANT_API_KEY=

# ── JWT ───────────────────────────────────────────────────────────────────────
# 生成：openssl rand -hex 64
JWT_SECRET=replace_with_64_byte_hex_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ── 加密 ──────────────────────────────────────────────────────────────────────
# 联系方式加密密钥（AES-256），必须与 JWT_SECRET 不同
# 生成：openssl rand -hex 32
CONTACT_ENCRYPTION_KEY=replace_with_32_byte_hex_string

# ── CORS ─────────────────────────────────────────────────────────────────────
# 前端域名，多个用逗号分隔
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ── LLM Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx
DEEPSEEK_API_KEY=sk-xxxx
VOYAGE_API_KEY=pa-xxxx
LLM_PRIMARY_PROVIDER=anthropic
LLM_FALLBACK_PROVIDER=deepseek
LLM_PRIMARY_MODEL=claude-sonnet-4-6
LLM_COMPLEX_MODEL=claude-opus-4-6
LLM_LIGHT_MODEL=claude-haiku-4-5-20251001
LLM_EMBEDDING_MODEL=voyage-3
LLM_MAX_MONTHLY_USD=100

# ── Firebase（FCM 推送，选填）────────────────────────────────────────────────
# 若不配置推送通知，留空即可（服务器仍可正常启动）
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_FILE=

# ── SendGrid（邮件，选填）────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=数字分身社区
