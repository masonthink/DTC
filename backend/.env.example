# =============================================================================
# digital-twin-community backend · Environment Variables
# 复制此文件为 .env 并填入实际值
# 生产环境使用 Cloud Secret Manager / GKE Secrets
# =============================================================================

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development           # development | staging | production
APP_VERSION=0.1.0
APP_DEBUG=true

# ─── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_RATE_LIMIT=100

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# 主库
DATABASE_URL=postgresql://dtc:dtc_dev_password@localhost:5432/digital_twin_community?sslmode=disable
# 匿名 ID 映射专用连接（最小权限）
ANON_DATABASE_URL=postgresql://dtc_anon:dtc_anon_password@localhost:5432/digital_twin_community?sslmode=disable&search_path=anon

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=dtc_dev_redis
REDIS_DB=0

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_API_KEY=
QDRANT_TLS_ENABLED=false
QDRANT_COLLECTION_AGENTS=agents
QDRANT_COLLECTION_TOPICS=topics

# ─── LLM Providers ────────────────────────────────────────────────────────────
# Anthropic (主力)
ANTHROPIC_API_KEY=sk-ant-xxxx

# OpenAI (备用/轻量任务)
OPENAI_API_KEY=sk-xxxx

# DeepSeek (成本优化备用)
DEEPSEEK_API_KEY=sk-xxxx

# Voyage AI (Embedding)
VOYAGE_API_KEY=pa-xxxx

# LLM 路由策略
LLM_PRIMARY_PROVIDER=anthropic
LLM_FALLBACK_PROVIDER=deepseek
LLM_PRIMARY_MODEL=claude-sonnet-4-6
LLM_COMPLEX_MODEL=claude-opus-4-6
LLM_LIGHT_MODEL=claude-haiku-4-5-20251001
LLM_EMBEDDING_MODEL=voyage-3
LLM_MAX_MONTHLY_USD=500

# ─── JWT ──────────────────────────────────────────────────────────────────────
# 生产环境必须使用强随机值 (openssl rand -hex 64)
JWT_SECRET=local-dev-secret-replace-in-production
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=720h

# ─── GCP / Cloud KMS ──────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
KMS_LOCATION=global
KMS_KEY_RING=digital-twin
KMS_KEY_ID=contact-encryption

# ─── Firebase (FCM 推送) ──────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_CREDENTIALS_FILE=/path/to/firebase-adminsdk.json

# ─── SendGrid (邮件) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxx
SENDGRID_FROM_EMAIL=noreply@digital-twin.community
SENDGRID_FROM_NAME=数字分身社区

# ─── Google Cloud Storage ─────────────────────────────────────────────────────
GCS_BUCKET_NAME=digital-twin-community-assets
